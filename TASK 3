#include <iostream>
using namespace std;

char board[3][3];

// Initialize the board with numbers 1-9 (helps players pick positions)
void initializeBoard() {
    int num = 1;
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            board[i][j] = '0' + num;
            num++;
        }
    }
}

// Display the current board
void displayBoard() {
    cout << "\n";
    for (int i = 0; i < 3; i++) {
        cout << " " << board[i][0] << " | " << board[i][1] << " | " << board[i][2] << " " << endl;
        if (i < 2) cout << "---|---|---" << endl;
    }
    cout << "\n";
}

// Update the board with the player's move
bool updateBoard(int position, char playerSymbol) {
    int row = (position - 1) / 3;
    int col = (position - 1) % 3;

    // Check if the position is valid and empty
    if (position < 1 || position > 9 || board[row][col] == 'X' || board[row][col] == 'O') {
        return false;
    }

    board[row][col] = playerSymbol;
    return true;
}

// Check if the current player has won
bool checkWin(char playerSymbol) {
    // Check rows and columns
    for (int i = 0; i < 3; i++) {
        if (board[i][0] == playerSymbol && board[i][1] == playerSymbol && board[i][2] == playerSymbol)
            return true;
        if (board[0][i] == playerSymbol && board[1][i] == playerSymbol && board[2][i] == playerSymbol)
            return true;
    }

    // Check diagonals
    if (board[0][0] == playerSymbol && board[1][1] == playerSymbol && board[2][2] == playerSymbol)
        return true;
    if (board[0][2] == playerSymbol && board[1][1] == playerSymbol && board[2][0] == playerSymbol)
        return true;

    return false;
}

// Check if the game is a draw (no empty spaces left)
bool checkDraw() {
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            if (board[i][j] != 'X' && board[i][j] != 'O') {
                return false;
            }
        }
    }
    return true;
}

int main() {
    char playAgain = 'y';

    while (playAgain == 'y' || playAgain == 'Y') {
        initializeBoard();
        char currentPlayer = 'X';
        bool gameWon = false;
        bool gameDraw = false;
        int position;

        cout << "=== TIC-TAC-TOE ===" << endl;
        cout << "Player 1: X   Player 2: O" << endl;
        cout << "Enter positions 1-9 as shown on the board.\n" << endl;

        while (!gameWon && !gameDraw) {
            displayBoard();

            cout << "Player " << currentPlayer << ", enter your move (1-9): ";
            cin >> position;

            // Validate input
            if (cin.fail() || !updateBoard(position, currentPlayer)) {
                cin.clear();
                cin.ignore(1000, '\n');
                cout << "Invalid move! That position is either taken or out of range. Try again.\n";
                continue;
            }

            gameWon = checkWin(currentPlayer);
            gameDraw = checkDraw();

            if (!gameWon && !gameDraw) {
                // Switch players
                currentPlayer = (currentPlayer == 'X') ? 'O' : 'X';
            }
        }

        displayBoard();

        if (gameWon) {
            cout << "Player " << currentPlayer << " wins! Congratulations!" << endl;
        } else if (gameDraw) {
            cout << "It's a draw! Good game." << endl;
        }

        cout << "\nDo you want to play again? (y/n): ";
        cin >> playAgain;
    }

    cout << "\nThanks for playing!" << endl;
    return 0;
}
